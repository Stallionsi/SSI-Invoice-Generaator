{
  "name": "invoice-generator-backend",
  "version": "1.0.0",
  "description": "Production-ready Invoice Generator Backend — MERN Stack",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "worker:email": "node src/jobs/email.worker.js",
    "worker:pdf": "node --max-old-space-size=512 src/jobs/pdf.worker.js",
    "worker:reminder": "node src/jobs/reminder.worker.js",
    "worker:recurring": "node src/jobs/recurring.worker.js",
    "worker:webhook": "node src/jobs/webhook.worker.js",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.js"
  },
  "dependencies": {
    "axios": "^1.6.8",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.7.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csv-writer": "^1.6.0",
    "dayjs": "^1.11.10",
    "decimal.js": "^10.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "joi": "^17.12.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.3.1",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.13",
    "pdfkit": "^0.15.2",
    "resend": "^6.9.4",
    "uuid": "^9.0.0",
    "winston": "^3.13.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^9.1.6",
    "nodemon": "^3.1.0",
    "supertest": "^7.0.0"
  },
  "keywords": [
    "invoice",
    "mern",
    "backend",
    "gst",
    "billing"
  ],
  "author": "Your Company",
  "license": "MIT"
