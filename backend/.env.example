# ─────────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─────────────────────────────────────────────
# MONGODB
# ─────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/invoice_generator
# Production example:
# MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/invoice_generator?retryWrites=true&w=majority

# ─────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_refresh_token_secret_change_in_production
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────────────
# REDIS (for BullMQ queues and caching)
# ─────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
# REDIS_URL=redis://:password@host:6379   (use this for cloud Redis)

# ─────────────────────────────────────────────
# EMAIL — Nodemailer (SMTP)
# ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Default FROM address shown in emails
EMAIL_FROM_NAME=Invoice Generator
EMAIL_FROM_ADDRESS=invoices@yourcompany.com

# ─────────────────────────────────────────────
# AWS SES (alternative to Nodemailer SMTP)
# AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY are read directly by the AWS SDK
# ─────────────────────────────────────────────
USE_AWS_SES=false
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# ─────────────────────────────────────────────
# IMAGEKIT (file & image storage)
# Get keys from: https://imagekit.io/dashboard/developer/api-keys
# ─────────────────────────────────────────────
IMAGEKIT_PUBLIC_KEY=public_xxxxxxxxxxxxxxxxxxxx
IMAGEKIT_PRIVATE_KEY=private_xxxxxxxxxxxxxxxxxxxx
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id
IMAGEKIT_FOLDER=invoice-generator

# ─────────────────────────────────────────────
# UPLOAD LIMITS
# ─────────────────────────────────────────────
MAX_FILE_SIZE_MB=10

# Local dir — used only for generated PDFs (not user uploads)
UPLOAD_DIR=uploads

# ─────────────────────────────────────────────
# RATE LIMITING
# ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─────────────────────────────────────────────
# FRONTEND URL (for CORS)
# ─────────────────────────────────────────────
CLIENT_URL=http://localhost:3000

# ─────────────────────────────────────────────
# INVOICE SETTINGS
# ─────────────────────────────────────────────
INVOICE_NUMBER_PREFIX=INV
INVOICE_NUMBER_PADDING=6

# ─────────────────────────────────────────────
# CURRENCY / EXCHANGE RATES
# ─────────────────────────────────────────────
DEFAULT_CURRENCY=INR
EXCHANGE_RATE_API_KEY=your_exchange_rate_api_key
# Get free key from: https://www.exchangerate-api.com

# ─────────────────────────────────────────────
# WEBHOOKS
# ─────────────────────────────────────────────
WEBHOOK_SECRET=your_webhook_signing_secret

# ─────────────────────────────────────────────
# RESEND (transactional email — recommended over SMTP)
# Get API key from: https://resend.com/api-keys
# Set USE_RESEND=true to switch from SMTP/SES to Resend
# ─────────────────────────────────────────────
USE_RESEND=false
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────
# LOGGING
# ─────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=logs
